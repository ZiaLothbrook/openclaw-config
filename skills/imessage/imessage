#!/usr/bin/env python3
"""
iMessage skill — send iMessages via AppleScript.
Usage: ./imessage send <phone_number> <message>
"""

import argparse
import subprocess
import sys


def send_imessage(to: str, body: str) -> None:
    # Normalize number format
    number = to.strip()

    script = f'''
tell application "Messages"
    set targetBuddy to buddy "{number}" of service "SMS"
    send "{body}" to targetBuddy
end tell
'''

    result = subprocess.run(
        ["osascript", "-e", script],
        capture_output=True,
        text=True,
        timeout=15,
    )

    if result.returncode != 0:
        # Fallback: try iMessage service directly
        script_fallback = f'''
tell application "Messages"
    send "{body}" to buddy "{number}"
end tell
'''
        result2 = subprocess.run(
            ["osascript", "-e", script_fallback],
            capture_output=True,
            text=True,
            timeout=15,
        )
        if result2.returncode != 0:
            print(f"ERROR: {result2.stderr.strip() or result.stderr.strip()}", file=sys.stderr)
            sys.exit(1)

    print(f"Sent iMessage to {number}")


parser = argparse.ArgumentParser(description="iMessage CLI")
subparsers = parser.add_subparsers(dest="command", required=True)

send_p = subparsers.add_parser("send", help="Send an iMessage")
send_p.add_argument("to", help="Recipient phone number (e.g. +13033453071)")
send_p.add_argument("body", help="Message text")

args = parser.parse_args()

if args.command == "send":
    send_imessage(args.to, args.body)
