<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.deepgem.imessage-poller</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>-c</string>
        <string>/Library/Developer/CommandLineTools/usr/bin/python3 -u /Users/jarvis/jarvis-config/scripts/poll-imessage.py</string>
    </array>

    <!-- Long-running daemon — script loops internally every 30s -->
    <key>KeepAlive</key>
    <true/>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/jarvis/Library/Logs/Jarvis/imessage-poller.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/jarvis/Library/Logs/Jarvis/imessage-poller-error.log</string>

    <key>WorkingDirectory</key>
    <string>/Users/jarvis/jarvis-config</string>
</dict>
</plist>
