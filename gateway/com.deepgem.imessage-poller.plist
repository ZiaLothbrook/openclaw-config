<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.deepgem.imessage-poller</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/bin/python3</string>
        <string>/Users/jarvis/jarvis-config/scripts/poll-imessage.py</string>
    </array>

    <!-- Run every 30 seconds -->
    <key>StartInterval</key>
    <integer>30</integer>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/Users/jarvis/Library/Logs/Jarvis/imessage-poller.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/jarvis/Library/Logs/Jarvis/imessage-poller-error.log</string>

    <key>WorkingDirectory</key>
    <string>/Users/jarvis/jarvis-config</string>
</dict>
</plist>
